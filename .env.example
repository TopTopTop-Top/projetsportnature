# Base PostgreSQL (local : docker compose up -d)
DATABASE_URL=postgresql://ravitobox:ravitobox@localhost:5432/ravitobox
# Désactiver SSL pour Postgres local sans TLS
DATABASE_SSL=false

# Render : copier l’URL interne ou externe fournie par la base PostgreSQL
